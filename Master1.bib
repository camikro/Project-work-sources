}

@article{jiaLargeElectrostrainHigh2021,
  title = {Large Electrostrain and High Energy-Storage of (1-{\emph{x}})[0.94({{Bi0}}.{{5Na0}}.5) {{TiO3-0}}.{{06BaTiO3}}]-{\emph{x}}{{Ba}}({{Sn0}}.{{70Nb0}}.24){{O3}} Lead-Free Ceramics},
  author = {Jia, Yuxin and Fan, Huiqing and Wang, Han and Yadav, Arun Kumar and Yan, Benben and Li, Mengyuan and Quan, Qifeng and Dong, Guangzhi and Wang, Weijia and Li, Qiang},
  year = 2021,
  month = jul,
  journal = {Ceramics International},
  volume = {47},
  number = {13},
  pages = {18487--18496},
  issn = {0272-8842},
  doi = {10.1016/j.ceramint.2021.03.172},
  urldate = {2026-01-22},
  abstract = {(1-x)[0.94(Bi0.5Na0.5)TiO3-0.06BaTiO3]-xBa(Sn0.70Nb0.24)O3 (abbreviated as BNTBT-100xBSN) lead-free ceramics were fabricated with a relative density greater than 96 \%, and the structure as well as performance were tested. BNTBT-100xBSN ceramics are pseudo-cubic perovskite structure, with dense surface morphology. Doping BSN can effectively reduce the dielectric loss of ceramics and increase the relaxation properties to a certain extent. The randomly distributed ferroelectric phase was replaced by polar nano regions, thereby improving the electro-strain and energy storage performance of the system. The largest electro-strain and the corresponding normalized strain (d33*) reach~\textasciitilde ~0.43 \% and 633 pm/V respectively in the BNTBT-1BSN ceramic. The largest effective energy storage density reaching \textasciitilde{} 1.28~J/cm3 was tested in BNTBT-2BSN. BNTBT-100xBSN ceramics provide a feasible idea for the systematic research of lead-free ferroelectrics and improvements in electro-strain and energy storage applications.},
  keywords = {BiNaTiO-Based ceramics,Electrostrain,Energy-storage density,Ferroelectrics},
  file = {/Users/camillakrogh/Zotero/storage/KF7GBL94/Jia et al. - 2021 - Large electrostrain and high energy-storage of (1-x)[0.94(Bi0.5Na0.5) TiO3-0.06BaTiO3]-x.pdf;/Users/camillakrogh/Zotero/storage/UM2EENS5/S0272884221008592.html}
}

@article{jingResearchProgressPiezoelectric2025,
  title = {Research Progress of Piezoelectric Materials in Biomedicine},
  author = {Jing, Zhenfeng and Ge, Pinghui and Zhang, Haixia and Sun, Shuhui and Liu, Yuan and Jiang, Zhen and Zhang, Sen and Li, Xingfu and Pang, Hui and Zhang, Fengqing},
  year = 2025,
  month = sep,
  journal = {Smart Materials and Structures},
  volume = {34},
  number = {9},
  pages = {093002},
  publisher = {IOP Publishing},
  issn = {0964-1726},
  doi = {10.1088/1361-665X/ae0902},
  urldate = {2026-02-03},
  abstract = {Piezoelectric materials are able to generate charges with redox capabilities under the action of external mechanical stress, thereby achieving the conversion from mechanical energy to electrical energy and being widely utilized in biomedical research. Due to their good biocompatibility, high energy conversion efficiency, high biological activity, and stability, they show a bright prospect in future medical applications. Under the action of external force, piezoelectric materials are able to release electrons and holes, intervene in the living body to promote the occurrence of certain reactions, or provide a continuous power source for human devices to achieve medical purposes, such as tissue repair, drug release, cancer treatment, and biosensing. Piezoelectric biomedicine technology provides a more efficient and convenient means, improving the quality of life of patients. In order to promote the innovation of new medical technologies, especially the development of treatment methods, this paper systematically summarizes the latest research trends and the phased progress achieved in recent years of piezoelectric materials in the biomedical field. Firstly, the preparation techniques and basic classifications of piezoelectric materials are introduced. Different properties and application techniques of piezoelectric biomaterials are reviewed, and a brief summary of their multiple comprehensive applications in clinical practice is made. Finally, we discuss the challenges faced by piezoelectric materials in biomedicine and their future development directions, providing valuable insights and suggestions for subsequent research work.},
  langid = {english},
  file = {/Users/camillakrogh/Zotero/storage/VD9G8LJY/Jing et al. - 2025 - Research progress of piezoelectric materials in biomedicine.pdf}
}

