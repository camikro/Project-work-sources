@article{chen3DPrintedBismuth2025,
  title = {{{3D}} Printed Bismuth Sodium Titanate/Hydroxyapatite Piezoelectric Ceramics: As an Alternative Material for Bone Repair},
  shorttitle = {{{3D}} Printed Bismuth Sodium Titanate/Hydroxyapatite Piezoelectric Ceramics},
  author = {Chen, Kai and Sun, Xiumei and Zhang, Mingjun and Zheng, Shikang and Zou, Chentong and Wang, Lin and Liu, Yuyan and Tang, Haoyu and Zheng, Haoyu and Wang, Chao and Yu, Xiao and Wang, Fang and Wu, Guomin},
  year = 2025,
  month = mar,
  journal = {Materials Today Communications},
  volume = {44},
  pages = {112179},
  issn = {2352-4928},
  doi = {10.1016/j.mtcomm.2025.112179},
  urldate = {2026-03-13},
  abstract = {Addressing bone tissue defects arising from diverse causes has consistently posed a significant challenge and remains a focal point in both clinical practice and research endeavors. Research has illuminated the piezoelectric nature of natural bone tissue, prompting the recent adoption of piezoelectric biomaterials for the fabrication of bone tissue engineering scaffolds aimed at defect repair. In this investigation, we leveraged digital photocuring (DLP) technology to develop a bismuth sodium titanate/hydroxyapatite (BNT/HA) composite piezoelectric ceramic scaffold, intended for use as a bone substitute in defect remediation. Electrical property assessments reveal that the scaffold containing 90\,wt\% BNT exhibits a piezoelectric coefficient comparable to that of natural bone tissue (d33: 1.63 pC N-1). Furthermore, in vitro osteogenic evaluations demonstrate that the polarized BNT/HA composite piezoelectric ceramic scaffold not only maintains acceptable biosafety but also exhibits robust osteogenic potential when subjected to low-intensity pulsed ultrasound (LIPUS) stimulation. Taken together, the BNT/HA composite piezoelectric ceramic scaffold introduced in this study emerges as a promising novel biomaterial for bone tissue replacement, offering substantial application potential.},
  keywords = {3D-Printed,Bismuth sodium titanate,Electrical properties,Hydroxyapatite,Osteogenic properties,Piezoelectric ceramic},
  file = {/Users/camillakrogh/Zotero/storage/7M7575F8/Chen et al. - 2025 - 3D printed bismuth sodium titanatehydroxyapatite piezoelectric ceramics as an alternative material.pdf;/Users/camillakrogh/Zotero/storage/8EAN864A/S2352492825006919.html}
}

@article{chenPiezoelectricMaterialsBone2025,
  title = {Piezoelectric Materials for Bone Implants: {{Opportunities}} and Challenges},
  shorttitle = {Piezoelectric Materials for Bone Implants},
  author = {Chen, Xionggang and Zhang, Shiping and Peng, Shifeng and Qian, Yu and Zhou, Jianhong},
  year = 2025,
  month = jun,
  journal = {Nano Energy},
  volume = {138},
  pages = {110841},
  issn = {2211-2855},
  doi = {10.1016/j.nanoen.2025.110841},
  urldate = {2026-03-13},
  abstract = {The rapid advancement of modern medical technology and materials science has facilitated extensive research and application of artificial bone implants for treating bone defects. However, these implants still face challenges such as insufficient osseointegration and bacterial infections, which limit their clinical application. Piezoelectric materials have garnered considerable attention for their potential to promote bone repair and enhance the sustainability of medical applications. In this review, we systematically examine the advances in piezoelectric materials for bone implants. First, the potential of piezoelectric materials in addressing major clinical challenges in bone implantation are discussed. The most commonly used piezoelectric materials in bone implants, including inorganic and organic materials as well as piezoelectric composites, are classified and examined. Subsequently, we explore the various forms of piezoelectric materials used in bone implants, such as particles, coatings, and scaffolds, highlighting their advantages and limitations in improving osseointegration and preventing bacterial infections. Finally, the progress in the clinical application of piezoelectric materials is further analyzed, and both the opportunities and challenges they present in the treatment of bone defects are proposed. Overall, this review systematically examines the advances in piezoelectric materials for bone implants and aims to facilitate the development of novel piezoelectric materials and accelerate the transition of these materials from basic research to clinical application.},
  keywords = {Application,Bone,Implants,Piezoelectric},
  file = {/Users/camillakrogh/Zotero/storage/HGXE227W/Chen et al. - 2025 - Piezoelectric materials for bone implants Opportunities and challenges.pdf;/Users/camillakrogh/Zotero/storage/QQQULJ9M/S2211285525002009.html}
}

