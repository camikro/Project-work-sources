  urldate = {2026-03-13},
  abstract = {Piezoelectric materials are able to generate charges with redox capabilities under the action of external mechanical stress, thereby achieving the conversion from mechanical energy to electrical energy and being widely utilized in biomedical research. Due to their good biocompatibility, high energy conversion efficiency, high biological activity, and stability, they show a bright prospect in future medical applications. Under the action of external force, piezoelectric materials are able to release electrons and holes, intervene in the living body to promote the occurrence of certain reactions, or provide a continuous power source for human devices to achieve medical purposes, such as tissue repair, drug release, cancer treatment, and biosensing. Piezoelectric biomedicine technology provides a more efficient and convenient means, improving the quality of life of patients. In order to promote the innovation of new medical technologies, especially the development of treatment methods, this paper systematically summarizes the latest research trends and the phased progress achieved in recent years of piezoelectric materials in the biomedical field. Firstly, the preparation techniques and basic classifications of piezoelectric materials are introduced. Different properties and application techniques of piezoelectric biomaterials are reviewed, and a brief summary of their multiple comprehensive applications in clinical practice is made. Finally, we discuss the challenges faced by piezoelectric materials in biomedicine and their future development directions, providing valuable insights and suggestions for subsequent research work.},
  langid = {english},
  file = {/Users/camillakrogh/Zotero/storage/88TUJTGG/Jing et al. - 2025 - Research progress of piezoelectric materials in biomedicine.pdf}
}

@article{khareElectricalStimulationPiezoelectric2020,
  title = {Electrical Stimulation and Piezoelectric Biomaterials for Bone Tissue Engineering Applications},
  author = {Khare, Deepak and Basu, Bikramjit and Dubey, Ashutosh Kumar},
  year = 2020,
  month = nov,
  journal = {Biomaterials},
  volume = {258},
  pages = {120280},
  issn = {0142-9612},
  doi = {10.1016/j.biomaterials.2020.120280},
  urldate = {2026-03-10},
  abstract = {Bioelectrical phenomenon in natural bone has been well recognized for its role in bone development and fracture healing. For example, the piezoelectricity induced modulation in cellular functionality assists in the repair and regeneration of bone tissue. Against this backdrop, we review here the origin of dielectric and electrical responses (piezo-, pyro- and ferro-electricity) of natural bone along with their consequences in regulating the bone metabolic activities. The concept of piezoelectricity induced osteogenesis has driven the development of piezoimplants for bone regeneration applications. A number of recent studies have been critically analyzed to demonstrate as to how the surface charge polarization or electric field stimulation together with functional properties of piezoelectric biomaterials can synergistically modulate cell functionality, in vitro or tissue regeneration, in vivo. The examples are drawn from a range of piezoelectric bioceramics, (e.g. barium titanate, magnesium silicate etc.) and biopolymers (e.g. polyvinylidene fluoride (PVDF), collagen, etc). The challenging problem of processing the compositionally tailored bioceramics is emphasized in particular reference to (Na, K)NbO3, an implantable biomaterial with the most attractive combination of piezoresponsive properties. Taken together, this review comprehensively emphasizes the appealing relevance of piezo-bioceramics and piezo-biopolymers as next-generation orthopedic biomaterials.},
  keywords = {Electrical stimulation,Perovskites,Piezoelectric,Polarization,Processing},
  file = {/Users/camillakrogh/Zotero/storage/JHKFTKAJ/Khare et al. - 2020 - Electrical stimulation and piezoelectric biomaterials for bone tissue engineering applications.pdf;/Users/camillakrogh/Zotero/storage/8FZTIH73/S0142961220305263.html}
}

@article{kokuboApatiteFormationSurfaces1998,
