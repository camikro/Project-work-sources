@incollection{crossRelaxorFerroelectrics2008,
	location = {Berlin, Heidelberg},
	title = {Relaxor Ferroelectrics},
	isbn = {978-3-540-68683-5},
	url = {https://doi.org/10.1007/978-3-540-68683-5_5},
	doi = {10.1007/978-3-540-68683-5_5},
	abstract = {It is interesting to note that as with almost all initial advances in the study of ferroelectric oxides the impetus for studies of relaxor ferroelectrics stemmed from early work on polycrystalline ceramic systems. In the case of the relaxor ferroelectrics, the advance originated from studies in Professor Smolensky’s group at the Ioffe Institute in Leningrad (now St. Petersburg) on perovskite structure electroceramics of complex composition. Originally classified as ferroelectrics with diffuse phase transitions, it slowly became clear that the very high dielectric maximum being highly dispersive could not mark a classical ferroelectric phase transition. Now, following studies at Penn State University, the suggested designation as relaxor ferroelectrics has become internationally adopted. The name is nicely compact and does highlight two key features, the combination of massive dielectric relaxation with almost classical lower-temperature ferroelectric response.},
	pages = {131--155},
	booktitle = {Piezoelectricity: Evolution and Future of a Technology},
	publisher = {Springer},
	author = {Cross, L. E.},
	editor = {Heywang, Walter and Lubitz, Karl and Wersing, Wolfram},
	urldate = {2026-05-03},
	date = {2008},
	langid = {english},
	keywords = {Relaxor Ferroelectric, Barium Strontium Niobate, Morphotropic Phase Boundary, Niobium Pentoxide, Strontium Titanate},
	file = {Full Text PDF:files/646/Cross - 2008 - Relaxor Ferroelectrics.pdf:application/pdf},
}

