	keywords = {hydroxyapatite, tissue engineering, cell adhesion, manipulation, polarization, surface charge},
	file = {Full Text PDF:files/515/Ohgaki et al. - 2001 - Manipulation of selective cell adhesion and growth by surface charges of electrically polarized hydr.pdf:application/pdf;Snapshot:files/514/1097-4636(20011205)573366AID-JBM11793.0.html:text/html},
}

@article{pradhanElectricallyPolarizedHydroxyapatite2024,
	title = {Electrically polarized hydroxyapatite with Sr containing barium titanate incorporated with mangiferin for enhanced osteogenic and antibacterial activity},
	volume = {618},
	issn = {0015-0193},
	url = {https://doi.org/10.1080/00150193.2024.2324630},
	doi = {10.1080/00150193.2024.2324630},
	abstract = {An electrically active ceramic composite of Ca10({PO}4)6({OH})2 and {BaSrTiO}3 was studied for its possible therapeutic applications. This study offers an in-depth investigation into the material science aspects of composites, including their biological properties and dielectric interactions. The weight ratio of the mixed hydroxyapatite and ferroelectric barium strontium titanate was 60:40. The microstructure and phase composition of the composites were both characterized using X-ray diffraction analysis and scanning electron microscopy ({SEM}). As part of the in vitro study, mangiferin ({MANG}) was included in both unpolarized and polarized {HA}-{BST} composites. The {MTT} assay for cell viability showed enhanced osteoblast activity of the specimens. The polarized composite was found to be more effective than the unpolarized specimen in inhibiting the growth and attachment of Staphylococcus aureus. As a result, the polarized {HA}-{BST}-{MANG} composite has shown to be an effective bone substitute in encouraging osteoblast production and preventing bacterial infection.},
	pages = {1157--1169},
	number = {4},
	journaltitle = {Ferroelectrics},
	publisher = {Taylor \& Francis},
	author = {Pradhan, Monalisa and Swain, Subhasmita and Rautray, Tapash R.},
	urldate = {2026-03-14},
	date = {2024-03-11},
	note = {\_eprint: https://doi.org/10.1080/00150193.2024.2324630},
	file = {Full Text PDF:files/527/Pradhan et al. - 2024 - Electrically polarized hydroxyapatite with Sr containing barium titanate incorporated with mangiferi.pdf:application/pdf},
}

@article{hwangEffectPolingConditions2002,
	title = {Effect of poling conditions on growth of calcium phosphate crystal in ferroelectric {BaTiO}3 ceramics},
	volume = {13},
	issn = {1573-4838},
	url = {https://doi.org/10.1023/A:1013671526975},
	doi = {10.1023/A:1013671526975},
	abstract = {Recently, ceramic materials have been given a lot of attention as candidates for implant materials, since they possess biologically favorable characteristics for osseointegration. Among them, {BaTiO}3 ({BTO}) ceramics are ferroelectric and piezoelectric after poling treatments. However, little or no information is available on the poling condition of {BTO} and their effect on calcium phosphate ({CaP}) formation. In this study, the effect of poling conditions on the formation of {CaP} layer was investigated. It was observed from this study that {CaP} was formed on negatively charged {BTO} surfaces. An increase in Ca/P ratio to 1.67 was observed when the poling temperature was increased above the Curie temperature. On positively charged {BTO}, no {CaP} layer was observed.},
	pages = {133--138},
	number = {1},
	journaltitle = {Journal of Materials Science: Materials in Medicine},
	shortjournal = {Journal of Materials Science: Materials in Medicine},
	author = {Hwang, K. S. and Song, J. E. and Jo, J. W. and Yang, H. S. and Park, Y. J. and Ong, J. L. and Rawls, H. R.},
	urldate = {2026-03-14},
	date = {2002-01-01},
	langid = {english},
	keywords = {Polymer, {BaTiO}3, Calcium, Curie Temperature, Phosphate},
	file = {Full Text PDF:files/529/Hwang et al. - 2002 - Effect of poling conditions on growth of calcium phosphate crystal in ferroelectric BaTiO3 ceramics.pdf:application/pdf},
}

@article{hadjidakisBoneRemodeling2006,
	title = {Bone Remodeling},
	volume = {1092},
	issn = {1749-6632},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1196/annals.1365.035},
	doi = {10.1196/annals.1365.035},
	abstract = {Abstract: The skeleton is a metabolically active organ that undergoes continuous remodeling throughout life. Bone remodeling involves the removal of mineralized bone by osteoclasts followed by the formation of bone matrix through the osteoblasts that subsequently become mineralized. The remodeling cycle consists of three consecutive phases: resorption, during which osteoclasts digest old bone; reversal, when mononuclear cells appear on the bone surface; and formation, when osteoblasts lay down new bone until the resorbed bone is completely replaced. Bone remodeling serves to adjust bone architecture to meet changing mechanical needs and it helps to repair microdamages in bone matrix preventing the accumulation of old bone. It also plays an important role in maintaining plasma calcium homeostasis. The regulation of bone remodeling is both systemic and local. The major systemic regulators include parathyroid hormone ({PTH}), calcitriol, and other hormones such as growth hormone, glucocorticoids, thyroid hormones, and sex hormones. Factors such as insulin-like growth factors ({IGFs}), prostaglandins, tumor growth factor-beta ({TGF}-β), bone morphogenetic proteins ({BMP}), and cytokines are involved as well. As far as local regulation of bone remodeling is concerned, a large number of cytokines and growth factors that affect bone cell functions have been recently identified. Furthermore, through the {RANK}/receptor activator of {NF}-kappa B ligand ({RANKL})/osteoprotegerin ({OPG}) system the processes of bone resorption and formation are tightly coupled allowing a wave of bone formation to follow each cycle of bone resorption, thus maintaining skeletal integrity.},
	pages = {385--396},
	number = {1},
	journaltitle = {Annals of the New York Academy of Sciences},
	author = {Hadjidakis, Dimitrios J. and Androulakis, Ioannis I.},
	urldate = {2026-03-16},
	date = {2006},
	langid = {english},
	note = {\_eprint: https://nyaspubs.onlinelibrary.wiley.com/doi/pdf/10.1196/annals.1365.035},
	keywords = {bone remodeling, cytokines, osteoblast, osteoclast},
	file = {Full Text PDF:files/531/Hadjidakis og Androulakis - 2006 - Bone Remodeling.pdf:application/pdf;Snapshot:files/532/annals.1365.html:text/html},
}

