	urldate = {2026-03-13},
	date = {2020-09-15},
	keywords = {Bismuth-sodium titanate, Bone repair, In-vitro assessment, Piezoelectric ceramics, Surface polarity},
	file = {ScienceDirect Full Text PDF:files/444/Hermann-Muñoz et al. - 2020 - In-vitro bioactivity and cytotoxicity of polarized (Bi0.5Na0.5)TiO3 ceramics as a novel bioma.pdf:application/pdf;ScienceDirect Snapshot:files/443/S0167577X20307837.html:text/html},
}

@article{chen3DPrintedBismuth2025,
	title = {3D printed bismuth sodium titanate/hydroxyapatite piezoelectric ceramics: as an alternative material for bone repair},
	volume = {44},
	issn = {2352-4928},
	url = {https://www.sciencedirect.com/science/article/pii/S2352492825006919},
	doi = {10.1016/j.mtcomm.2025.112179},
	shorttitle = {3D printed bismuth sodium titanate/hydroxyapatite piezoelectric ceramics},
	abstract = {Addressing bone tissue defects arising from diverse causes has consistently posed a significant challenge and remains a focal point in both clinical practice and research endeavors. Research has illuminated the piezoelectric nature of natural bone tissue, prompting the recent adoption of piezoelectric biomaterials for the fabrication of bone tissue engineering scaffolds aimed at defect repair. In this investigation, we leveraged digital photocuring ({DLP}) technology to develop a bismuth sodium titanate/hydroxyapatite ({BNT}/{HA}) composite piezoelectric ceramic scaffold, intended for use as a bone substitute in defect remediation. Electrical property assessments reveal that the scaffold containing 90 wt\% {BNT} exhibits a piezoelectric coefficient comparable to that of natural bone tissue (d33: 1.63 {pC} N−1). Furthermore, in vitro osteogenic evaluations demonstrate that the polarized {BNT}/{HA} composite piezoelectric ceramic scaffold not only maintains acceptable biosafety but also exhibits robust osteogenic potential when subjected to low-intensity pulsed ultrasound ({LIPUS}) stimulation. Taken together, the {BNT}/{HA} composite piezoelectric ceramic scaffold introduced in this study emerges as a promising novel biomaterial for bone tissue replacement, offering substantial application potential.},
	pages = {112179},
	journaltitle = {Materials Today Communications},
	shortjournal = {Materials Today Communications},
	author = {Chen, Kai and Sun, Xiumei and Zhang, Mingjun and Zheng, Shikang and Zou, Chentong and Wang, Lin and Liu, Yuyan and Tang, Haoyu and Zheng, Haoyu and Wang, Chao and Yu, Xiao and Wang, Fang and Wu, Guomin},
	urldate = {2026-03-13},
	date = {2025-03-01},
	keywords = {Hydroxyapatite, 3D-Printed, Bismuth sodium titanate, Electrical properties, Osteogenic properties, Piezoelectric ceramic},
	file = {ScienceDirect Full Text PDF:files/454/Chen et al. - 2025 - 3D printed bismuth sodium titanatehydroxyapatite piezoelectric ceramics as an alternative material.pdf:application/pdf;ScienceDirect Snapshot:files/453/S2352492825006919.html:text/html},
}

@article{hermann-munozEffectPolingDirection2023,
	title = {Effect of poling direction of (Na0.5Bi0.5){TiO}3 ceramics on the in vitro response of {MC}3T3-E1 preosteoblasts and bacteria},
	volume = {49},
	issn = {0272-8842},
	url = {https://www.sciencedirect.com/science/article/pii/S027288422300562X},
	doi = {10.1016/j.ceramint.2023.03.001},
	abstract = {The use of smart materials as implantable devices for bone repair is an emerging field in which alternatives have been explored in the last decade, such as using piezoelectric ceramics to mimic bone self-healing ability using the direct piezoelectric effect (generation of charges under mechanical stress). Here, the feasibility of using (Na0.5Bi0.5){TiO}3 dense ceramics as a potential biomaterial for bone repair was studied. The effect of poling direction on the osteogenic properties of (Na0.5Bi0.5){TiO}3 ceramics was assessed through several indicators of osteoblast differentiation, including gene expression, cell morphology, and mineralization. An enhanced osteoconductivity, reflected in a higher amount of calcium deposits and the presence of large filopodia and dendritic cell morphology was observed on the negative side compared to non-poled, positive side, and controls. Regarding the ability of (Na0.5Bi0.5){TiO}3 ceramics to accelerate osteoblastic differentiation, after 14 days, the gene expression measured by real-time quantitative polymerase chain reaction showed an up-regulation of osteopontin and osteocalcin from exposure, usually expressed during the late stages of osteoblastic differentiation. In addition, the positive side surface generated an antibacterial ratio of almost 50\% on gram + bacteria, possibly due to the interaction between the positively charged surface and the membrane's negatively charged bacteria. The results reported here show that tunable (Na0.5Bi0.5){TiO}3 ceramics have osteoconductive and antibacterial properties suitable for bone repair applications. Further studies are needed to deepen the understanding of the effect of the polarization level on the osteogenic and antibacterial properties.},
	pages = {18800--18808},
	number = {11},
	journaltitle = {Ceramics International},
	shortjournal = {Ceramics International},
	author = {Hermann-Muñoz, J. A. and Rincón-López, J. A. and Detsch, R. and Alvarado-Orozco, J. M. and Muñoz-Saldaña, J. and Boccaccini, A. R.},
	urldate = {2026-03-13},
	date = {2023-06-01},
	keywords = {Bioceramics, Antibacterial properties, In vitro osteogenesis},
	file = {ScienceDirect Full Text PDF:files/457/Hermann-Muñoz et al. - 2023 - Effect of poling direction of (Na0.5Bi0.5)TiO3 ceramics on the in vitro response of MC3T3-E1 preoste.pdf:application/pdf;ScienceDirect Snapshot:files/456/S027288422300562X.html:text/html},
}

